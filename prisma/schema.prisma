generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SearchStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum AutomationEligibility {
  UNKNOWN
  ALLOWED
  BLOCKED
  NEEDS_REVIEW
}

enum DetectedPlatform {
  UNKNOWN
  FOREUP
  GOLFNOW
  TEEITUP
  CHRONOGOLF
  CLUB_CADDIE
  CUSTOM
}

enum BookingMethod {
  UNKNOWN
  PUBLIC_ONLINE
  PHONE_ONLY
  ONLINE_OR_PHONE
  CONTACT_COURSE
  WALK_IN
}

enum BookingWindowSource {
  PROVIDER_CONFIG
  PROVIDER_MESSAGE
  OFFICIAL_BOOKING_PAGE
}

enum AutomationReason {
  NONE
  NO_ONLINE_BOOKING
  UNSUPPORTED_PLATFORM
  AUTOMATION_PROHIBITED
  ACCOUNT_REQUIRED
  CAPTCHA_OR_QUEUE
  TEMPORARILY_UNAVAILABLE
  OTHER
}

enum ProbeOutcome {
  MATCH_FOUND
  NO_MATCH
  BLOCKED_POLICY
  BLOCKED_AUTH
  BLOCKED_TOOLING
  FETCH_FAILED
  NEEDS_ADAPTER
}

enum AlertStatus {
  PENDING
  SENT
  SUPPRESSED
}

enum SearchEmailDeliveryKind {
  SETUP
  DAILY
  MATCH
}

enum SearchEmailDeliveryStatus {
  PENDING
  SENDING
  SENT
  SUPPRESSED
  FAILED
}

enum SearchCheckStatus {
  IDLE
  QUEUED
  CHECKING
  WAITING
  FAILED
  STOPPED
}

enum MatchAvailabilityStatus {
  AVAILABLE
  GONE
  UNKNOWN
}

enum FeedbackSentiment {
  LIKE
  DISLIKE
  BROKEN
}

enum WebsiteTrafficClass {
  UNCLASSIFIED
  PUBLIC
  AUTOMATION
  TEST
}

enum GooglePlaceAccessOverride {
  VERIFIED_PUBLIC
  VERIFIED_PRIVATE
  VERIFIED_NON_COURSE
}

enum CourseSupportIncidentStatus {
  AUTO_INVESTIGATING
  NEEDS_HUMAN
  RESOLVED
}

enum CourseSupportIncidentKind {
  NEEDS_ADAPTER
  FETCH_FAILED
  BLOCKED_AUTH
  BLOCKED_TOOLING
}

enum CourseSupportResolution {
  MONITORING_RESTORED
  DIRECT_BOOKING_CLASSIFIED
}

enum CourseSupportFailureClass {
  MISSING_SOURCE
  MISSING_METADATA
  UNSUPPORTED_FAMILY
  AUTH
  RATE_LIMIT
  CHALLENGE
  NOT_FOUND
  HTTP_5XX
  TIMEOUT
  NETWORK
  SCHEMA
  UNKNOWN
}

enum CourseSupportBatchStatus {
  CLAIMED
  IMPLEMENTING
  VERIFYING
  SUCCEEDED
  PARTIAL
  RETRYABLE_FAILED
}

enum CourseSupportBatchIncidentResult {
  PENDING
  RESTORED
  FINAL_DISPOSITION
  RETRY_SCHEDULED
  NEEDS_HUMAN
  STALE_EVIDENCE
}

enum CourseSupportVerificationStatus {
  QUEUED
  CHECKING
  SUCCEEDED
  RETRYABLE_FAILED
  STALE
}

enum CourseProfileStatus {
  PENDING
  PUBLISHED
  BLOCKED_EVIDENCE
  STALE
}

enum CourseProfileType {
  MUNICIPAL
  DAILY_FEE
  RESORT
  UNIVERSITY
  MILITARY
  SEMI_PRIVATE
  OTHER_PUBLIC
}

enum CourseProfileSourceType {
  OFFICIAL_COURSE
  OFFICIAL_OPERATOR
  MUNICIPAL_GOVERNMENT
  OFFICIAL_BOOKING
  GOLF_ASSOCIATION
  GOVERNMENT_TOURISM
  ESTABLISHED_NEWS
  GOOGLE_PLACE_IDENTITY
}

model User {
  id                     String      @id @default(cuid())
  clerkUserId            String      @unique
  email                  String
  clerkUserUpdatedAt     DateTime?
  pendingEmail           String?
  pendingEmailObservedAt DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  teeSearches            TeeSearch[]

  @@index([pendingEmailObservedAt])
}

model Course {
  id                          String                             @id @default(cuid())
  googlePlaceId               String?                            @unique
  name                        String
  address                     String?
  city                        String?
  stateCode                   String?
  stateName                   String?
  county                      String?
  countryCode                 String?
  latitude                    Float
  longitude                   Float
  timeZone                    String                             @default("America/New_York")
  rating                      Float?
  website                     String?
  phone                       String?
  isPublic                    Boolean                            @default(true)
  isManual                    Boolean                            @default(false)
  detectedBookingUrl          String?
  detectedPlatform            DetectedPlatform                   @default(UNKNOWN)
  providerFamilyKey           String                             @default("SOURCE_MISSING")
  bookingMethod               BookingMethod                      @default(UNKNOWN)
  bookingPhone                String?
  bookingWindowDaysAhead      Int?
  bookingReleaseTimeLocal     String?
  bookingWindowSource         BookingWindowSource?
  bookingWindowConfidence     Float?
  bookingWindowEvidenceUrl    String?
  bookingWindowCheckedAt      DateTime?
  bookingWindowObservedAt     DateTime?
  automationEligibility       AutomationEligibility              @default(UNKNOWN)
  automationReason            AutomationReason                   @default(NONE)
  policyNotes                 String?
  bookingMetadata             Json?
  intelligenceVerifiedAt      DateTime?
  intelligenceReviewAt        DateTime?
  intelligenceConfidence      Float?
  layoutHoleCounts            Int[]                              @default([])
  layoutHolesEvidenceUrl      String?
  layoutHolesVerifiedAt       DateTime?
  par                         Int?
  parEvidenceUrl              String?
  parVerifiedAt               DateTime?
  createdAt                   DateTime                           @default(now())
  updatedAt                   DateTime                           @updatedAt
  preferences                 CoursePreference[]
  probes                      CourseProbe[]
  matches                     TeeTimeMatch[]
  automationDiscoveries       CourseAutomationDiscovery[]
  supportIncident             CourseSupportIncident?
  supportBatchIncidents       CourseSupportBatchIncident[]
  supportVerificationRequests CourseSupportVerificationRequest[]
  profile                     CourseProfile?

  @@index([latitude, longitude])
  @@index([stateCode, county, automationEligibility])
  @@index([detectedPlatform, automationEligibility])
  @@index([providerFamilyKey, automationEligibility])
  @@index([bookingMethod, automationEligibility])
  @@index([intelligenceReviewAt])
}

model CourseProfile {
  id                    String                   @id @default(cuid())
  courseId              String                   @unique
  canonicalSlug         String                   @unique
  status                CourseProfileStatus      @default(PENDING)
  courseType            CourseProfileType?
  accessSummary         String?
  overview              String?
  courseCharacter       String?
  notableFacts          String[]                 @default([])
  contentHash           String?
  contentVersion        Int                      @default(1)
  profileVerifiedAt     DateTime?
  reviewDueAt           DateTime?
  publishedAt           DateTime?
  lastResearchAttemptAt DateTime?
  lastRefreshedAt       DateTime?
  failedResearchAt      DateTime?
  failureReason         String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  course                Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sources               CourseProfileSource[]
  slugAliases           CourseProfileSlugAlias[]

  @@index([status, reviewDueAt])
  @@index([publishedAt])
}

model CourseProfileSource {
  id              String                  @id @default(cuid())
  courseProfileId String
  url             String
  title           String
  publisher       String
  sourceType      CourseProfileSourceType
  claimKeys       String[]                @default([])
  evidenceSummary String
  accessedAt      DateTime
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  courseProfile   CourseProfile           @relation(fields: [courseProfileId], references: [id], onDelete: Cascade)

  @@unique([courseProfileId, url])
  @@index([courseProfileId, sourceType])
}

model CourseProfileSlugAlias {
  id              String        @id @default(cuid())
  courseProfileId String
  slug            String        @unique
  createdAt       DateTime      @default(now())
  courseProfile   CourseProfile @relation(fields: [courseProfileId], references: [id], onDelete: Cascade)

  @@index([courseProfileId])
}

model GooglePlaceReview {
  id                        String                     @id @default(cuid())
  googlePlaceId             String                     @unique
  accessOverride            GooglePlaceAccessOverride?
  name                      String
  classification            String
  evidenceUrl               String
  reviewedAt                DateTime
  active                    Boolean                    @default(true)
  canonicalPlaceId          String?
  canonicalName             String?
  canonicalAddress          String?
  canonicalWebsiteUrl       String?
  canonicalPhone            String?
  latitude                  Float?
  longitude                 Float?
  retainWhenCanonicalAbsent Boolean                    @default(false)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([active, accessOverride])
  @@index([canonicalPlaceId])
}

model TeeSearch {
  id                         String                     @id @default(cuid())
  userId                     String
  date                       DateTime
  startTime                  String
  endTime                    String
  userTimeZone               String                     @default("America/New_York")
  players                    Int
  requestedLayoutHoles       Int?
  cadenceMinutes             Int                        @default(5)
  additionalEmails           String[]                   @default([])
  trafficClass               WebsiteTrafficClass        @default(UNCLASSIFIED)
  syntheticMultiCycle        Boolean                    @default(false)
  status                     SearchStatus               @default(ACTIVE)
  checkStatus                SearchCheckStatus          @default(IDLE)
  scheduleVersion            Int                        @default(0)
  alertGeneration            Int                        @default(0)
  workflowRunId              String?
  checkLeaseToken            String?
  checkLeaseExpiresAt        DateTime?
  recheckRequestedAt         DateTime?
  remediationDispatchKey     String?
  remediationDispatchVersion Int?
  nextCheckAt                DateTime?
  lastCheckedAt              DateTime?
  lastCheckOutcome           String?
  statusEmailSentAt          DateTime?
  statusEmailSnapshot        Json?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  user                       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences                CoursePreference[]
  probes                     CourseProbe[]
  matches                    TeeTimeMatch[]
  emailDeliveries            SearchEmailDelivery[]
  courseSupportRechecks      CourseSupportBatchSearch[]

  @@index([status, date])
  @@index([status, nextCheckAt])
  @@index([checkLeaseExpiresAt])
  @@index([userId, status])
  @@index([trafficClass, status, date])
}

model SearchEmailDelivery {
  id               String                    @id @default(cuid())
  teeSearchId      String
  alertGeneration  Int
  kind             SearchEmailDeliveryKind
  groupKey         String
  recipient        String
  isOwnerRecipient Boolean                   @default(false)
  payload          Json
  status           SearchEmailDeliveryStatus @default(PENDING)
  claimToken       String?
  claimExpiresAt   DateTime?
  attemptCount     Int                       @default(0)
  nextAttemptAt    DateTime?
  sentAt           DateTime?
  lastError        String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  teeSearch        TeeSearch                 @relation(fields: [teeSearchId], references: [id], onDelete: Cascade)

  @@unique([teeSearchId, alertGeneration, kind, groupKey, recipient])
  @@index([status, nextAttemptAt])
  @@index([teeSearchId, alertGeneration, status])
  @@index([claimExpiresAt])
}

model CoursePreference {
  id          String    @id @default(cuid())
  teeSearchId String
  courseId    String
  rank        Int
  createdAt   DateTime  @default(now())
  teeSearch   TeeSearch @relation(fields: [teeSearchId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([teeSearchId, courseId])
  @@unique([teeSearchId, rank])
  @@index([courseId])
}

model CourseProbe {
  id              String         @id @default(cuid())
  teeSearchId     String
  courseId        String
  automationRunId String?
  outcome         ProbeOutcome
  observedAt      DateTime       @default(now())
  message         String?
  evidenceUrl     String?
  rawSummary      Json?
  runtimeVersion  String?
  teeSearch       TeeSearch      @relation(fields: [teeSearchId], references: [id], onDelete: Cascade)
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  automationRun   AutomationRun? @relation(fields: [automationRunId], references: [id], onDelete: SetNull)

  @@index([teeSearchId, observedAt])
  @@index([courseId, observedAt])
  @@index([observedAt])
}

model TeeTimeMatch {
  id                 String                  @id @default(cuid())
  teeSearchId        String
  courseId           String
  sourceId           String
  startsAt           DateTime
  availabilityCycle  Int                     @default(0)
  availableSpots     Int
  priceCents         Int?
  holes              Int?
  bookingUrl         String
  evidenceUrl        String?
  alertStatus        AlertStatus             @default(PENDING)
  availabilityStatus MatchAvailabilityStatus @default(AVAILABLE)
  firstSeenAt        DateTime                @default(now())
  lastSeenAt         DateTime                @default(now())
  lastConfirmedAt    DateTime                @default(now())
  unavailableAt      DateTime?
  sentAt             DateTime?
  teeSearch          TeeSearch               @relation(fields: [teeSearchId], references: [id], onDelete: Cascade)
  course             Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([teeSearchId, courseId, sourceId, startsAt])
  @@index([alertStatus, firstSeenAt])
  @@index([teeSearchId, availabilityStatus, startsAt])
  @@index([firstSeenAt])
}

model AutomationRun {
  id             String               @id @default(cuid())
  promptVersion  String
  startedAt      DateTime             @default(now())
  completedAt    DateTime?
  outcome        String?
  errors         Json?
  changedFiles   Json?
  notes          String?
  probes         CourseProbe[]
  supportBatches CourseSupportBatch[] @relation("SupportBatchOwner")

  @@index([startedAt])
  @@index([promptVersion, startedAt])
}

model CourseAutomationDiscovery {
  id                    String                @id @default(cuid())
  courseId              String
  status                String
  detectedPlatform      DetectedPlatform      @default(UNKNOWN)
  bookingMethod         BookingMethod         @default(UNKNOWN)
  bookingPhone          String?
  automationEligibility AutomationEligibility @default(UNKNOWN)
  automationReason      AutomationReason      @default(NONE)
  sourceUrl             String
  bookingUrl            String?
  apiEndpoint           String?
  apiMetadata           Json?
  evidence              Json?
  confidence            Float                 @default(0)
  createdAt             DateTime              @default(now())
  course                Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
  @@index([status, createdAt])
  @@index([detectedPlatform, createdAt])
  @@index([bookingMethod, createdAt])
  @@index([createdAt])
}

model CourseSupportIncident {
  id                    String                       @id @default(cuid())
  courseId              String                       @unique
  firstAffectedSearchId String?
  cycle                 Int                          @default(1)
  status                CourseSupportIncidentStatus  @default(AUTO_INVESTIGATING)
  kind                  CourseSupportIncidentKind
  providerFamilyKey     String                       @default("SOURCE_MISSING")
  failureClass          CourseSupportFailureClass    @default(UNKNOWN)
  failureFingerprint    String                       @default("UNKNOWN")
  courseNameSnapshot    String
  platformSnapshot      DetectedPlatform
  bookingUrlSnapshot    String?
  initialMessage        String?
  latestMessage         String?
  nextAction            String?
  affectedSearchCount   Int                          @default(1)
  occurrenceCount       Int                          @default(1)
  engineeringOnly       Boolean                      @default(false)
  nextAttemptAt         DateTime?
  lastAttemptAt         DateTime?
  attemptCount          Int                          @default(0)
  activeRealSearchCount Int                          @default(0)
  earliestTargetDate    DateTime?
  activeBatchId         String?
  firstSeenAt           DateTime                     @default(now())
  lastSeenAt            DateTime                     @default(now())
  ownerNotifiedAt       DateTime?
  escalatedAt           DateTime?
  escalationNotifiedAt  DateTime?
  resolvedAt            DateTime?
  resolution            CourseSupportResolution?
  resolutionMessage     String?
  resolutionNotifiedAt  DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  course                Course                       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  activeBatch           CourseSupportBatch?          @relation("ActiveCourseSupportBatch", fields: [activeBatchId], references: [id], onDelete: SetNull)
  batchIncidents        CourseSupportBatchIncident[]

  @@index([status, lastSeenAt])
  @@index([status, nextAttemptAt])
  @@index([providerFamilyKey, failureFingerprint, status])
  @@index([activeBatchId])
  @@index([ownerNotifiedAt])
  @@index([resolutionNotifiedAt])
}

model CourseSupportBatch {
  id                       String                       @id @default(cuid())
  reference                String                       @unique
  providerFamilyKey        String
  failureFingerprint       String
  status                   CourseSupportBatchStatus     @default(CLAIMED)
  ownerAutomationRunId     String?
  ownerThreadId            String?
  leaseToken               String
  leaseExpiresAt           DateTime
  heartbeatAt              DateTime
  baseSha                  String
  releaseSha               String?
  deployedAt               DateTime?
  recheckDispatchKey       String?
  recheckDispatchStartedAt DateTime?
  recheckDispatchedAt      DateTime?
  completedAt              DateTime?
  revision                 Int                          @default(0)
  maxCourses               Int                          @default(5)
  summary                  Json?
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  ownerAutomationRun       AutomationRun?               @relation("SupportBatchOwner", fields: [ownerAutomationRunId], references: [id], onDelete: SetNull)
  activeIncidents          CourseSupportIncident[]      @relation("ActiveCourseSupportBatch")
  incidents                CourseSupportBatchIncident[]
  searchDispatches         CourseSupportBatchSearch[]

  @@index([status, leaseExpiresAt])
  @@index([providerFamilyKey, failureFingerprint, createdAt])
  @@index([ownerAutomationRunId])
}

model CourseSupportBatchIncident {
  id                        String                             @id @default(cuid())
  batchId                   String
  incidentId                String
  courseId                  String
  cycle                     Int
  result                    CourseSupportBatchIncidentResult   @default(PENDING)
  preProbeId                String?
  postProbeId               String?
  message                   String?
  proofSnapshot             Json?
  verifiedIncidentUpdatedAt DateTime?
  verifiedAt                DateTime?
  createdAt                 DateTime                           @default(now())
  updatedAt                 DateTime                           @updatedAt
  batch                     CourseSupportBatch                 @relation(fields: [batchId], references: [id], onDelete: Cascade)
  incident                  CourseSupportIncident              @relation(fields: [incidentId], references: [id], onDelete: Restrict)
  course                    Course                             @relation(fields: [courseId], references: [id], onDelete: Restrict)
  verificationRequests      CourseSupportVerificationRequest[]

  @@unique([batchId, incidentId])
  @@index([incidentId])
  @@index([courseId])
  @@index([result, updatedAt])
}

model CourseSupportVerificationRequest {
  id                            String                          @id @default(cuid())
  batchIncidentId               String
  courseId                      String
  releaseSha                    String
  runtimeVersion                String?
  status                        CourseSupportVerificationStatus @default(QUEUED)
  revision                      Int                             @default(0)
  leaseToken                    String?
  leaseExpiresAt                DateTime?
  workflowRunId                 String?
  nextAttemptAt                 DateTime?
  attemptCount                  Int                             @default(0)
  targetDateLocal               String
  startTimeLocal                String                          @default("06:00")
  endTimeLocal                  String                          @default("20:00")
  timeZone                      String
  players                       Int                             @default(1)
  providerFamilyKeySnapshot     String
  platformSnapshot              DetectedPlatform
  bookingMethodSnapshot         BookingMethod
  automationEligibilitySnapshot AutomationEligibility
  automationReasonSnapshot      AutomationReason
  providerSnapshotFingerprint   String
  providerSnapshotAt            DateTime
  discoveryAttemptedAt          DateTime?
  discoveryVerifiedAt           DateTime?
  outcome                       ProbeOutcome?
  failureClass                  CourseSupportFailureClass?
  evidence                      Json?
  lastError                     String?
  startedAt                     DateTime?
  completedAt                   DateTime?
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  batchIncident                 CourseSupportBatchIncident      @relation(fields: [batchIncidentId], references: [id], onDelete: Cascade)
  course                        Course                          @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@unique([batchIncidentId, releaseSha], map: "CourseSupportVerification_batchIncident_release_key")
  @@index([status, nextAttemptAt], map: "CourseSupportVerification_status_nextAttempt_idx")
  @@index([leaseExpiresAt], map: "CourseSupportVerification_leaseExpiresAt_idx")
  @@index([courseId, status], map: "CourseSupportVerification_course_status_idx")
  @@index([releaseSha, status], map: "CourseSupportVerification_release_status_idx")
}

model CourseSupportBatchSearch {
  id              String             @id @default(cuid())
  batchId         String
  teeSearchId     String?
  searchRef       String
  scheduleVersion Int
  removedAt       DateTime?
  removalReason   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  batch           CourseSupportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  teeSearch       TeeSearch?         @relation(fields: [teeSearchId], references: [id], onDelete: SetNull)

  @@unique([batchId, searchRef])
  @@index([teeSearchId])
  @@index([batchId, removedAt])
}

model ProviderRequestLease {
  providerFamilyKey String
  slot              Int
  leaseToken        String
  leaseExpiresAt    DateTime
  updatedAt         DateTime @updatedAt

  @@id([providerFamilyKey, slot])
  @@index([leaseExpiresAt])
}

model WebsiteEvent {
  id           String              @id @default(cuid())
  name         String
  page         String?
  metadata     Json?
  trafficClass WebsiteTrafficClass @default(UNCLASSIFIED)
  createdAt    DateTime            @default(now())

  @@index([name, createdAt])
  @@index([trafficClass, createdAt])
  @@index([createdAt])
}

model WebsiteFeedback {
  id           String              @id @default(cuid())
  sentiment    FeedbackSentiment
  message      String?
  page         String?
  contactEmail String?
  trafficClass WebsiteTrafficClass @default(UNCLASSIFIED)
  createdAt    DateTime            @default(now())
  resolvedAt   DateTime?

  @@index([sentiment, createdAt])
  @@index([trafficClass, createdAt])
  @@index([createdAt])
}
